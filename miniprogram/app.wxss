page {
  min-height: 100%;
  background: #f6f6f6;
  color: #161616;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.card {
  background: #ffffff;
  border: 1px solid #e7e7e7;
  border-radius: 20rpx;
  padding: 28rpx;
  box-sizing: border-box;
}

.btn-primary {
  background: #111111;
  color: #ffffff;
  border-radius: 999rpx;
  font-size: 30rpx;
}

.btn-ghost {
  background: #ffffff;
  color: #111111;
  border: 1px solid #d8d8d8;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.muted {
  color: #777777;
}
