<view class="page">
  <view class="hero">
    <view class="eyebrow">Aluminum Frame Designer</view>
    <view class="title">铝型材结构设计器</view>
    <view class="subtitle">输入尺寸，生成 3D 框架与材料清单。衣柜、书桌、支架、置物架，都可以从结构语言开始。</view>
  </view>

  <view class="card action-card">
    <view class="section-title">快速开始</view>
    <view class="section-desc">先用 2000×600×750mm 书桌模板跑通 MVP。</view>
    <button class="btn-primary" bindtap="createDemoProject">创建示例书桌</button>
  </view>

  <view class="card">
    <view class="section-title">本地项目</view>
    <block wx:if="{{projects.length === 0}}">
      <view class="empty">暂无项目。创建一个结构，让材料清单自己长出来。</view>
    </block>
    <block wx:for="{{projects}}" wx:key="id">
      <view class="project-item" bindtap="openProject" data-id="{{item.id}}">
        <view>
          <view class="project-name">{{item.name}}</view>
          <view class="project-meta">{{item.size.width}}×{{item.size.depth}}×{{item.size.height}}mm · {{item.profile.code}}</view>
        </view>
        <view class="project-arrow">›</view>
      </view>
    </block>
  </view>
</view>
